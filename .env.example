# Copy this file to ".env" and fill in real values. Do NOT commit ".env".

# --- Turso database (stores contact/quote-request submissions) ---
# Create a database, then run:  turso db show <name> --url   and   turso db tokens create <name>
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Admin dashboard ---
# Password used to log in at /admin. Use something long and random.
ADMIN_SECRET=change-me-to-a-long-random-password
