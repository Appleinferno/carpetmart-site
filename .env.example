# Copy this file to ".env" and fill in real values. Do NOT commit ".env".

# --- Turso database (stores contact/quote-request submissions) ---
# Create a database, then run:  turso db show <name> --url   and   turso db tokens create <name>
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Admin dashboard ---
# Password used to log in at /admin. Use something long and random.
ADMIN_SECRET=change-me-to-a-long-random-password

# --- Email notifications for new leads (optional; uses Resend) ---
# Leave RESEND_API_KEY blank to disable email — the form still saves to the DB.
# Get a key at resend.com. FROM must be a Resend-verified domain in production;
# onboarding@resend.dev works for testing (delivers to the account owner only).
RESEND_API_KEY=
LEAD_NOTIFY_TO=info@carpetmartfloors.com
LEAD_NOTIFY_FROM=Carpet Mart Leads <onboarding@resend.dev>
