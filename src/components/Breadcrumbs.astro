---
interface Props {
  items: { name: string; path: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="container-page pt-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-stone-500">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && <span class="text-stone-300">/</span>}
          {i < items.length - 1 ? (
            <a href={item.path} class="hover:text-clay-700">{item.name}</a>
          ) : (
            <span class="font-medium text-stone-700" aria-current="page">{item.name}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
