---
import Logo from './Logo.astro';
import MobileNav from './MobileNav.tsx';
import { NAV_LINKS, SITE } from '../lib/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 w-full">
  <!-- Utility bar -->
  <div class="hidden bg-stone-900 text-stone-300 md:block">
    <div class="container-page flex h-9 items-center justify-between text-xs">
      <p class="tracking-wide">
        Family-owned in Murphy, NC since {SITE.foundedYear} &middot; Free in-store estimates
      </p>
      <div class="flex items-center gap-5">
        <a href={SITE.maps} class="hover:text-white" target="_blank" rel="noopener">
          {SITE.address.street}, {SITE.address.city} {SITE.address.region}
        </a>
        <a href={`tel:${SITE.phoneHref}`} class="font-mono font-medium text-white hover:text-clay-200">
          {SITE.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- Main bar -->
  <div class="border-b border-stone-200/80 bg-stone-50/85 backdrop-blur-xl">
    <div class="container-page flex h-16 items-center justify-between gap-4 sm:h-[4.5rem]">
      <a href="/" class="shrink-0" aria-label="Carpet Mart home">
        <Logo />
      </a>

      <nav class="hidden items-center gap-5 lg:flex xl:gap-6">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class:list={[
                'relative text-sm font-medium transition-colors',
                isActive(link.href)
                  ? 'text-clay-700'
                  : 'text-stone-600 hover:text-stone-900',
              ]}
            >
              {link.label}
              {isActive(link.href) && (
                <span class="absolute -bottom-1.5 left-0 h-0.5 w-full rounded-full bg-clay-600" />
              )}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2.5">
        <a
          href={`tel:${SITE.phoneHref}`}
          class="hidden items-center gap-2 rounded-lg border border-stone-300 px-3.5 py-2 text-sm font-medium text-stone-800 transition-all hover:border-stone-400 hover:bg-white active:scale-[0.98] xl:inline-flex"
        >
          <svg class="h-4 w-4 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <span class="font-mono">{SITE.phone}</span>
        </a>
        <a
          href="/contact/"
          class="hidden rounded-lg bg-clay-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-all hover:bg-clay-700 active:scale-[0.98] sm:inline-flex"
        >
          Get a Free Quote
        </a>
        <MobileNav client:load navLinks={NAV_LINKS} phone={SITE.phone} phoneHref={SITE.phoneHref} />
      </div>
    </div>
  </div>
</header>
