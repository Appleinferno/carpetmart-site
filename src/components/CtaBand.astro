---
import { SITE } from '../lib/site';
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = 'Ready to start your flooring project?',
  text = 'Tell us about your rooms and we\'ll take it from there — a free in-home measure, an all-in quote, and professional installation by our own crews. One company, start to finish.',
} = Astro.props;
---

<section class="container-page">
  <div class="relative overflow-hidden rounded-3xl bg-stone-900 px-6 py-14 sm:px-12 sm:py-16">
    <!-- subtle clay glow, tinted to background -->
    <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-clay-700/30 blur-3xl"></div>
    <div class="relative grid items-center gap-8 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <h2 class="max-w-xl text-3xl font-bold leading-tight text-white sm:text-4xl">{heading}</h2>
        <p class="mt-4 max-w-xl text-[1.0625rem] leading-relaxed text-stone-300">{text}</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-xl bg-clay-600 px-6 py-3.5 text-base font-semibold text-white transition-all hover:bg-clay-500 active:scale-[0.98]"
        >
          Get a free quote
        </a>
        <a
          href={`tel:${SITE.phoneHref}`}
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-stone-700 px-6 py-3.5 text-base font-semibold text-white transition-all hover:bg-stone-800 active:scale-[0.98]"
        >
          <svg class="h-5 w-5 text-clay-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <span class="font-mono">{SITE.phone}</span>
        </a>
      </div>
    </div>
  </div>
</section>
