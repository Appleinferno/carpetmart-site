---
import Logo from './Logo.astro';
import { SITE, FLOORING_CATEGORIES, NAV_LINKS } from '../lib/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-stone-800 bg-stone-950 text-stone-400">
  <div class="container-page grid gap-12 py-14 sm:grid-cols-2 lg:grid-cols-12">
    <!-- Brand + NAP -->
    <div class="lg:col-span-4">
      <Logo tone="light" />
      <p class="mt-5 max-w-xs text-sm leading-relaxed text-stone-400">
        Flooring and cabinets — sold and professionally installed by the same family in
        Murphy since {SITE.foundedYear}.
      </p>
      <address class="mt-6 space-y-2 text-sm not-italic">
        <a href={SITE.maps} target="_blank" rel="noopener" class="flex items-start gap-2.5 hover:text-white">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-clay-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <span>{SITE.address.street}<br />{SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}</span>
        </a>
        <a href={`tel:${SITE.phoneHref}`} class="flex items-center gap-2.5 hover:text-white">
          <svg class="h-4 w-4 shrink-0 text-clay-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <span class="font-mono">{SITE.phone}</span>
        </a>
      </address>
    </div>

    <!-- Flooring -->
    <div class="lg:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Flooring</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        {FLOORING_CATEGORIES.map((c) => (
          <li>
            <a href={`/flooring/${c.slug}`} class="hover:text-white">{c.name}</a>
          </li>
        ))}
        <li><a href="/flooring" class="text-clay-400 hover:text-clay-300">All flooring &rarr;</a></li>
      </ul>
    </div>

    <!-- Company -->
    <div class="lg:col-span-2">
      <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Company</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        {NAV_LINKS.filter((l) => l.href !== '/flooring').map((l) => (
          <li><a href={l.href} class="hover:text-white">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Hours -->
    <div class="lg:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Store Hours</h3>
      <ul class="mt-4 space-y-2 text-sm">
        {SITE.hours.map((h) => (
          <li class="flex items-baseline justify-between gap-3 border-b border-stone-800/80 pb-2">
            <span class="text-stone-400">{h.days}</span>
            <span class="font-mono text-stone-200">{h.time}</span>
          </li>
        ))}
      </ul>
      <a href="/contact" class="mt-5 inline-flex rounded-lg bg-clay-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-clay-700">
        Request a quote
      </a>
    </div>
  </div>

  <div class="border-t border-stone-800">
    <div class="container-page flex flex-col items-center justify-between gap-4 py-6 text-xs text-stone-500 sm:flex-row">
      <p>&copy; {year} {SITE.name} &middot; {SITE.tagline}. All rights reserved.</p>
      <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2" aria-label="Legal">
        <a href="/terms" class="hover:text-stone-300">Terms of Service</a>
        <a href="/cookie-policy" class="hover:text-stone-300">Cookie Policy</a>
        <a href="/trademark" class="hover:text-stone-300">Trademark</a>
      </nav>
    </div>
  </div>
</footer>
