---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { breadcrumbSchema } from '../lib/schema';

interface Props {
  title: string; // SEO <title>
  description: string;
  heading: string; // visible H1
  pageName: string; // breadcrumb + crumb label
  path: string; // e.g. /terms
  lastUpdated: string;
}

const { title, description, heading, pageName, path, lastUpdated } = Astro.props;

const crumbs = [
  { name: 'Home', path: '/' },
  { name: pageName, path },
];
---

<BaseLayout title={title} description={description} structuredData={breadcrumbSchema(crumbs)}>
  <Breadcrumbs items={crumbs} />

  <section class="container-page py-10 lg:py-14">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Legal</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight text-stone-900 sm:text-5xl">
        {heading}
      </h1>
      <p class="mt-4 text-sm text-stone-500">Last updated: {lastUpdated}</p>
    </div>

    <article class="prose prose-stone mt-10 max-w-3xl prose-headings:font-display prose-headings:tracking-tight prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10 prose-h3:text-lg prose-a:font-medium prose-a:text-clay-700 prose-a:underline-offset-2 hover:prose-a:text-clay-800 prose-strong:text-stone-900 prose-li:marker:text-clay-500">
      <slot />
    </article>
  </section>
</BaseLayout>
