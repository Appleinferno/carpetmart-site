---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SITE } from '../../lib/site';
import { localBusinessSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/flooring-guides/' },
  { name: data.title, path: `/flooring-guides/${entry.id}/` },
];

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: data.title,
    description: data.description,
    image: data.image ? `${SITE.url}${data.image}` : undefined,
    datePublished: data.pubDate.toISOString(),
    dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
    author: { '@type': 'Organization', name: data.author, url: SITE.url },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      logo: { '@type': 'ImageObject', url: `${SITE.url}/logo.svg` },
    },
    mainEntityOfPage: `${SITE.url}/flooring-guides/${entry.id}`,
  },
  localBusinessSchema,
  breadcrumbSchema(crumbs),
];
---

<BaseLayout
  title={`${data.title} | Carpet Mart`}
  description={data.description}
  ogImage={data.image}
  ogType="article"
  author={data.author}
  publishDate={data.pubDate.toISOString()}
  modifiedDate={(data.updatedDate ?? data.pubDate).toISOString()}
  tags={data.tags}
  structuredData={structuredData}
>
  <Breadcrumbs items={crumbs} />

  <article class="container-page py-8 lg:py-12">
    <header class="mx-auto max-w-3xl">
      <div class="flex flex-wrap items-center gap-2 text-sm text-stone-500">
        <time datetime={data.pubDate.toISOString()}>{fmt(data.pubDate)}</time>
        {data.tags.length > 0 && <span class="text-stone-300">/</span>}
        {data.tags.slice(0, 3).map((t) => (
          <span class="rounded-full bg-stone-100 px-2.5 py-0.5 text-xs font-medium text-stone-600">{t}</span>
        ))}
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-[1.1] tracking-tight text-stone-900 sm:text-5xl">{data.title}</h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-600">{data.description}</p>
    </header>

    {data.image && (
      <div class="mx-auto mt-10 max-w-4xl overflow-hidden rounded-3xl border border-stone-200">
        <img src={data.image} alt={data.imageAlt ?? data.title} width="1200" height="675" fetchpriority="high" class="aspect-[16/9] w-full object-cover" />
      </div>
    )}

    <div class="prose prose-stone mx-auto mt-12 max-w-3xl prose-headings:font-display prose-headings:tracking-tight prose-h2:text-2xl prose-h2:font-bold prose-h3:text-xl prose-a:font-medium prose-a:text-clay-700 prose-a:underline-offset-2 hover:prose-a:text-clay-800 prose-strong:text-stone-900">
      <Content />
    </div>

    <div class="mx-auto mt-12 max-w-3xl border-t border-stone-200 pt-8">
      <a href="/flooring-guides/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-clay-700 hover:text-clay-800">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15m0 0 6 6m-6-6 6-6"/></svg>
        All flooring guides
      </a>
    </div>
  </article>

  <div class="pt-8 pb-24">
    <CtaBand />
  </div>
</BaseLayout>
