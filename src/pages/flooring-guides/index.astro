---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SITE } from '../../lib/site';
import { localBusinessSchema, breadcrumbSchema } from '../../lib/schema';

const title = 'Flooring Guides & Tips | Carpet Mart, Murphy NC';
const description =
  'Practical flooring advice from Carpet Mart in Murphy, NC — comparisons, cost guides and tips for choosing the right floors for mountain homes, cabins and rentals.';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const [featured, ...rest] = posts;

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/flooring-guides/' },
];

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const structuredData = [localBusinessSchema, breadcrumbSchema(crumbs)];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <Breadcrumbs items={crumbs} />

  <section class="container-page py-10 lg:py-14">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Flooring guides</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.07] tracking-tight text-stone-900 sm:text-5xl">
        Straight talk on choosing floors
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-600">
        Fifty years of flooring mountain homes taught us a few things. Here's the same honest advice
        we'd give you across the counter — what holds up, what's worth the money, and what to skip.
      </p>
    </div>

    {featured && (
      <a href={`/flooring-guides/${featured.id}/`} class="group mt-12 grid overflow-hidden rounded-3xl border border-stone-200 bg-white transition-all hover:border-clay-300 hover:shadow-md lg:grid-cols-2">
        <div class="relative min-h-[16rem] overflow-hidden bg-stone-900">
          {featured.data.image && (
            <img src={featured.data.image} alt={featured.data.imageAlt ?? featured.data.title} width="900" height="600" class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-500 group-hover:scale-105" />
          )}
        </div>
        <div class="flex flex-col justify-center p-7 sm:p-10">
          <div class="flex flex-wrap items-center gap-2 text-xs">
            <span class="rounded-full bg-clay-100 px-2.5 py-1 font-semibold text-clay-700">Featured</span>
            <time class="text-stone-500">{fmt(featured.data.pubDate)}</time>
          </div>
          <h2 class="mt-3 font-display text-2xl font-bold text-stone-900 sm:text-3xl">{featured.data.title}</h2>
          <p class="mt-3 max-w-md text-[1.0625rem] leading-relaxed text-stone-600">{featured.data.description}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-clay-700">
            Read the guide
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
          </span>
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map((post) => (
          <a href={`/flooring-guides/${post.id}/`} class="group flex flex-col overflow-hidden rounded-2xl border border-stone-200 bg-white transition-all hover:border-clay-300 hover:shadow-sm">
            <div class="relative aspect-[16/10] overflow-hidden bg-stone-900">
              {post.data.image && (
                <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} width="600" height="375" loading="lazy" class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-500 group-hover:scale-105" />
              )}
            </div>
            <div class="flex flex-1 flex-col p-6">
              <time class="text-xs text-stone-500">{fmt(post.data.pubDate)}</time>
              <h2 class="mt-2 font-display text-lg font-bold text-stone-900">{post.data.title}</h2>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-stone-600">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <div class="pt-6 pb-24">
    <CtaBand />
  </div>
</BaseLayout>
