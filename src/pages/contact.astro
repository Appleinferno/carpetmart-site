---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.tsx';
import { SITE, ADDRESS_LINE } from '../lib/site';
import { localBusinessSchema, breadcrumbSchema } from '../lib/schema';

const title = 'Contact Carpet Mart | Flooring Quotes in Murphy, NC — (828) 837-7491';
const description =
  'Contact Carpet Mart in Murphy, NC for a free flooring quote. Visit our showroom at 1395 US Hwy 64 W, call (828) 837-7491, or send us your project details online.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact/' },
];

const structuredData = [localBusinessSchema, breadcrumbSchema(crumbs)];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <Breadcrumbs items={crumbs} />

  <section class="container-page py-10 lg:py-14">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Get in touch</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.07] tracking-tight text-stone-900 sm:text-5xl">
        Let's price your new floors
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-600">
        Send us a few details and we'll get back to you with next steps, or just call the showroom.
        Estimates are always free, and there's never any pressure.
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[1.2fr_1fr] lg:gap-16">
      <!-- FORM -->
      <div class="rounded-3xl border border-stone-200 bg-white p-6 sm:p-8">
        <h2 class="font-display text-2xl font-bold text-stone-900">Request a free quote</h2>
        <p class="mt-2 text-sm text-stone-500">We typically reply within one business day.</p>
        <div class="mt-6">
          <ContactForm client:load />
        </div>
      </div>

      <!-- DETAILS -->
      <aside class="space-y-6">
        <div class="rounded-3xl border border-stone-200 bg-white p-6 sm:p-8">
          <h2 class="font-display text-lg font-bold text-stone-900">Showroom &amp; contact</h2>
          <ul class="mt-5 space-y-4 text-sm">
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              <div>
                <p class="font-medium text-stone-900">Address</p>
                <a href={SITE.maps} target="_blank" rel="noopener" class="text-stone-600 hover:text-clay-700">{ADDRESS_LINE}</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
              <div>
                <p class="font-medium text-stone-900">Phone</p>
                <a href={`tel:${SITE.phoneHref}`} class="font-mono text-stone-600 hover:text-clay-700">{SITE.phone}</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
              <div>
                <p class="font-medium text-stone-900">Email</p>
                <a href={`mailto:${SITE.email}`} class="text-stone-600 hover:text-clay-700">{SITE.email}</a>
              </div>
            </li>
          </ul>

          <div class="mt-6 border-t border-stone-200 pt-5">
            <p class="font-medium text-stone-900">Store hours</p>
            <ul class="mt-3 space-y-2 text-sm">
              {SITE.hours.map((h) => (
                <li class="flex items-baseline justify-between gap-3">
                  <span class="text-stone-600">{h.days}</span>
                  <span class="font-mono text-stone-900">{h.time}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="overflow-hidden rounded-3xl border border-stone-200">
          <iframe
            title="Map to Carpet Mart, 1395 US Hwy 64 W, Murphy, NC"
            src="https://www.google.com/maps?q=1395%20US%20Hwy%2064%20W%2C%20Murphy%2C%20NC%2028906&output=embed"
            width="100%"
            height="280"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
