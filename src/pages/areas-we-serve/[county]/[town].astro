---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CtaBand from '../../../components/CtaBand.astro';
import { SITE, FLOORING_CATEGORIES, YEARS_IN_BUSINESS } from '../../../lib/site';
import { COUNTIES, countyPath, townPath } from '../../../lib/service-areas';
import { localBusinessSchema, breadcrumbSchema } from '../../../lib/schema';

export function getStaticPaths() {
  return COUNTIES.flatMap((county) =>
    county.towns.map((town) => ({
      params: { county: county.slug, town: town.slug },
      props: { county, town },
    }))
  );
}

const { county, town } = Astro.props;

// Sibling towns in the same county (for internal linking).
const siblings = county.towns.filter((t) => t.slug !== town.slug);

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Areas We Serve', path: '/areas-we-serve' },
  { name: county.name, path: countyPath(county) },
  { name: town.name, path: townPath(county, town) },
];

const title = `Flooring in ${town.name}, ${town.state} | Carpet & Installation — Carpet Mart`;
const description = `Flooring sales and professional installation in ${town.name}, ${town.state}. Carpet, vinyl plank, hardwood, vinyl flooring and laminate, measured and installed by Carpet Mart of Murphy. Free quote: ${SITE.phone}.`;

const mapQuery = encodeURIComponent(`${town.name}, ${town.state}`);

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `Flooring installation in ${town.name}, ${town.state}`,
    serviceType: 'Flooring sales & installation',
    provider: { '@id': `${SITE.url}/#business` },
    areaServed: { '@type': 'City', name: `${town.name}, ${town.state}` },
    url: `${SITE.url}${townPath(county, town)}`,
  },
  localBusinessSchema,
  breadcrumbSchema(crumbs),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <Breadcrumbs items={crumbs} />

  <!-- HERO -->
  <section class="container-page py-10 lg:py-14">
    <div class="grid gap-10 lg:grid-cols-[1.3fr_1fr] lg:gap-16">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">
          <a href={countyPath(county)} class="hover:text-clay-800">{county.name}, {county.state}</a>
        </p>
        <h1 class="mt-3 text-4xl font-extrabold leading-[1.07] tracking-tight text-stone-900 sm:text-5xl">
          Flooring in {town.name}, {town.state}
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-stone-600">{town.intro}</p>

        <div class="prose-body mt-6 space-y-4">
          <p>
            Carpet Mart has served {town.name} and the rest of {county.name} from our Murphy
            showroom for over {YEARS_IN_BUSINESS} years. We handle the whole project for you — we
            come out to measure, help you choose the right floor, and our own crews install it.
            One local company, from your first quote to the final board.
          </p>
        </div>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class="inline-flex items-center justify-center rounded-xl bg-clay-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm transition-all hover:bg-clay-700 active:scale-[0.98]">
            Get a free quote
          </a>
          <a href={`tel:${SITE.phoneHref}`} class="inline-flex items-center justify-center gap-2 rounded-xl border border-stone-300 bg-white px-6 py-3.5 text-base font-semibold text-stone-800 transition-all hover:border-stone-400 active:scale-[0.98]">
            <span class="font-mono">{SITE.phone}</span>
          </a>
        </div>
      </div>

      <aside class="space-y-5">
        {town.highlights.length > 0 && (
          <div class="rounded-2xl border border-stone-200 bg-white p-6">
            <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Around {town.name}</h2>
            <ul class="mt-3 space-y-2">
              {town.highlights.map((h) => (
                <li class="flex items-center gap-2 text-sm font-medium text-stone-700">
                  <svg class="h-4 w-4 shrink-0 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        )}
        <div class="overflow-hidden rounded-2xl border border-stone-200">
          <iframe
            title={`Map of ${town.name}, ${town.state}`}
            src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
            width="100%"
            height="220"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </aside>
    </div>
  </section>

  <!-- FLOORING WE INSTALL -->
  <section class="border-y border-stone-200 bg-white">
    <div class="container-page py-14">
      <h2 class="text-2xl font-bold tracking-tight text-stone-900">Flooring we sell &amp; install in {town.name}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {FLOORING_CATEGORIES.map((cat) => (
          <a href={`/flooring/${cat.slug}`} class="group rounded-2xl border border-stone-200 bg-stone-50 p-6 transition-all hover:border-clay-300 hover:shadow-sm">
            <h3 class="font-display text-lg font-bold text-stone-900 group-hover:text-clay-700">{cat.name}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-stone-600">{cat.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NEARBY TOWNS -->
  {siblings.length > 0 && (
    <section class="container-page py-14">
      <h2 class="text-2xl font-bold tracking-tight text-stone-900">We also serve nearby</h2>
      <div class="mt-6 flex flex-wrap gap-2.5">
        {siblings.map((t) => (
          <a href={townPath(county, t)} class="inline-flex rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-700 transition-colors hover:border-clay-300 hover:text-clay-700">
            {t.name}, {t.state}
          </a>
        ))}
        <a href={countyPath(county)} class="inline-flex rounded-full border border-clay-200 bg-clay-50 px-4 py-2 text-sm font-medium text-clay-700 hover:bg-clay-100">
          All of {county.name} &rarr;
        </a>
      </div>
    </section>
  )}

  <div class="pb-24">
    <CtaBand heading={`Ready for new floors in ${town.name}?`} />
  </div>
</BaseLayout>
