---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SITE, ADDRESS_LINE } from '../../lib/site';
import { COUNTIES_BY_STATE, countyPath, townPath, TOTAL_COUNTIES, TOTAL_TOWNS } from '../../lib/service-areas';
import { localBusinessSchema, breadcrumbSchema } from '../../lib/schema';

const title = 'Areas We Serve | Flooring Across NC, GA & TN Within 80 Miles of Murphy';
const description =
  'Carpet Mart sells and installs flooring across far Western NC, North Georgia and Southeast Tennessee — Cherokee, Clay, Graham, Macon, Union, Towns, Fannin and Polk counties. Within ~80 miles of Murphy.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Areas We Serve', path: '/areas-we-serve' },
];

const stateOrder = ['North Carolina', 'Georgia', 'Tennessee'];
const stateAbbr: Record<string, string> = { 'North Carolina': 'NC', Georgia: 'GA', Tennessee: 'TN' };

const structuredData = [localBusinessSchema, breadcrumbSchema(crumbs)];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <Breadcrumbs items={crumbs} />

  <section class="container-page py-10 lg:py-14">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Where we work</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.07] tracking-tight text-stone-900 sm:text-5xl">
        Flooring across the NC, GA &amp; TN mountains
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-600">
        From our showroom on US-64 in Murphy, we sell <em>and</em> install flooring for homes within
        about an 80-mile radius — {TOTAL_TOWNS} communities across {TOTAL_COUNTIES} counties and
        three states. We come to you to measure, then bring our own crews back to install. Pick your
        county below to see the towns we serve and what we install there.
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[1.4fr_1fr] lg:gap-16">
      <div class="space-y-12">
        {stateOrder.map((stateName) => (
          <div>
            <h2 class="flex items-center gap-3 font-display text-2xl font-bold text-stone-900">
              <span class="rounded-md bg-clay-100 px-2 py-0.5 text-sm font-bold text-clay-700">{stateAbbr[stateName]}</span>
              {stateName}
            </h2>
            <div class="mt-5 grid gap-4 sm:grid-cols-2">
              {COUNTIES_BY_STATE[stateName]?.map((c) => (
                <div class="rounded-2xl border border-stone-200 bg-white p-6">
                  <a href={countyPath(c)} class="group inline-flex items-center gap-1.5">
                    <h3 class="font-display text-lg font-bold text-stone-900 group-hover:text-clay-700">{c.name}</h3>
                    <svg class="h-4 w-4 text-clay-600 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
                  </a>
                  <p class="mt-0.5 text-xs text-stone-500">County seat: {c.seat}</p>
                  <ul class="mt-3 flex flex-wrap gap-1.5">
                    {c.towns.map((t) => (
                      <li>
                        <a href={townPath(c, t)} class="inline-flex rounded-full border border-stone-200 bg-stone-50 px-2.5 py-1 text-xs font-medium text-stone-600 hover:border-clay-300 hover:text-clay-700">
                          {t.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="overflow-hidden rounded-3xl border border-stone-200">
          <iframe
            title="Map to Carpet Mart in Murphy, NC"
            src="https://www.google.com/maps?q=1395%20US%20Hwy%2064%20W%2C%20Murphy%2C%20NC%2028906&output=embed"
            width="100%"
            height="320"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <div class="bg-white p-6">
            <h2 class="font-display text-lg font-bold text-stone-900">Visit the showroom</h2>
            <p class="mt-2 text-sm text-stone-600">{ADDRESS_LINE}</p>
            <a href={`tel:${SITE.phoneHref}`} class="mt-1 inline-block font-mono text-sm font-medium text-clay-700">{SITE.phone}</a>
            <a href="/contact" class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-clay-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-clay-700">
              Request a quote
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="container-page py-6">
    <div class="rounded-3xl border border-clay-200 bg-clay-50 p-8 sm:p-10">
      <h2 class="font-display text-2xl font-bold text-stone-900">Don't see your town?</h2>
      <p class="prose-body mt-3 max-w-3xl">
        These are the communities we serve most, but our 80-mile radius covers a lot of ground. If
        you're anywhere in the Tri-State mountain area, call us at
        <a href={`tel:${SITE.phoneHref}`} class="font-mono font-medium text-clay-700">{SITE.phone}</a>
        — chances are we can help.
      </p>
    </div>
  </section>

  <div class="pt-10 pb-24">
    <CtaBand />
  </div>
</BaseLayout>
