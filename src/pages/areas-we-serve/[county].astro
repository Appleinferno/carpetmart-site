---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import { SITE } from '../../lib/site';
import { FLOORING_CATEGORIES } from '../../lib/site';
import { COUNTIES, getCounty, countyPath, townPath } from '../../lib/service-areas';
import { localBusinessSchema, breadcrumbSchema } from '../../lib/schema';

export function getStaticPaths() {
  return COUNTIES.map((c) => ({ params: { county: c.slug } }));
}

const { county: countySlug } = Astro.params;
const county = getCounty(countySlug!);
if (!county) return Astro.redirect('/areas-we-serve');

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Areas We Serve', path: '/areas-we-serve' },
  { name: county.name, path: countyPath(county) },
];

const title = `Flooring in ${county.name}, ${county.state} | Carpet Mart`;
const description = `Carpet sales and installation across ${county.name}, ${county.stateName} — ${county.towns
  .map((t) => t.name)
  .join(', ')}. Free in-home measure and quote from Carpet Mart in Murphy.`;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `Flooring sales & installation in ${county.name}, ${county.state}`,
    serviceType: 'Flooring installation',
    provider: { '@id': `${SITE.url}/#business` },
    areaServed: { '@type': 'AdministrativeArea', name: `${county.name}, ${county.stateName}` },
    url: `${SITE.url}${countyPath(county)}`,
  },
  localBusinessSchema,
  breadcrumbSchema(crumbs),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <Breadcrumbs items={crumbs} />

  <section class="container-page py-10 lg:py-14">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">
        {county.stateName} &middot; County seat: {county.seat}
      </p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.07] tracking-tight text-stone-900 sm:text-5xl">
        Flooring in {county.name}, {county.state}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-600">{county.overview}</p>
      <p class="mt-3 text-sm font-medium text-stone-500">{county.driveNote}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a href="/contact" class="inline-flex items-center justify-center rounded-xl bg-clay-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm transition-all hover:bg-clay-700 active:scale-[0.98]">
          Get a free quote
        </a>
        <a href={`tel:${SITE.phoneHref}`} class="inline-flex items-center justify-center gap-2 rounded-xl border border-stone-300 bg-white px-6 py-3.5 text-base font-semibold text-stone-800 transition-all hover:border-stone-400 active:scale-[0.98]">
          <span class="font-mono">{SITE.phone}</span>
        </a>
      </div>
    </div>

    <!-- TOWNS -->
    <div class="mt-12">
      <h2 class="text-2xl font-bold tracking-tight text-stone-900">Towns we serve in {county.name}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {county.towns.map((t) => (
          <a href={townPath(county, t)} class="group flex flex-col rounded-2xl border border-stone-200 bg-white p-6 transition-all hover:border-clay-300 hover:shadow-sm">
            <div class="flex items-center justify-between">
              <h3 class="font-display text-xl font-bold text-stone-900 group-hover:text-clay-700">{t.name}, {t.state}</h3>
              <svg class="h-5 w-5 text-clay-600 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-stone-600 line-clamp-3">{t.intro}</p>
            <span class="mt-3 text-sm font-semibold text-clay-700">Flooring in {t.name} &rarr;</span>
          </a>
        ))}
      </div>
    </div>

    <!-- FLOORING REMINDER -->
    <div class="mt-14">
      <h2 class="text-2xl font-bold tracking-tight text-stone-900">What we install in {county.name}</h2>
      <div class="mt-6 flex flex-wrap gap-2.5">
        {FLOORING_CATEGORIES.map((cat) => (
          <a href={`/flooring/${cat.slug}`} class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-700 transition-colors hover:border-clay-300 hover:text-clay-700">
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="pt-6 pb-24">
    <CtaBand heading={`Serving ${county.name} from our Murphy showroom`} />
  </div>
</BaseLayout>
