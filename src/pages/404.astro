---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FLOORING_CATEGORIES, SITE } from '../lib/site';
---

<BaseLayout title="Page Not Found | Carpet Mart" description="That page couldn't be found." noindex={true}>
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="font-mono text-sm font-semibold uppercase tracking-[0.2em] text-clay-700">404</p>
    <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-stone-900 sm:text-5xl">
      We couldn't find that page
    </h1>
    <p class="mt-4 max-w-md text-lg text-stone-600">
      The page may have moved. Let's get you back to the floors — or give us a call at
      <a href={`tel:${SITE.phoneHref}`} class="font-mono font-medium text-clay-700">{SITE.phone}</a>.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="rounded-xl bg-clay-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-clay-700">
        Back home
      </a>
      <a href="/flooring/" class="rounded-xl border border-stone-300 bg-white px-6 py-3 text-sm font-semibold text-stone-800 transition-colors hover:border-stone-400">
        Browse flooring
      </a>
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-2">
      {FLOORING_CATEGORIES.map((c) => (
        <a href={`/flooring/${c.slug}/`} class="rounded-full border border-stone-300 bg-white px-4 py-1.5 text-sm font-medium text-stone-600 hover:border-clay-300 hover:text-clay-700">
          {c.name}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
