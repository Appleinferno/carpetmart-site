---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import TeamSection from '../components/TeamSection.astro';
import FAQ from '../components/FAQ.tsx';
import { SITE, FLOORING_CATEGORIES, TESTIMONIALS, YEARS_IN_BUSINESS, ADDRESS_LINE } from '../lib/site';
import { ALL_TOWNS, townPath, TOTAL_COUNTIES, TOTAL_TOWNS } from '../lib/service-areas';
import { localBusinessSchema, faqSchema } from '../lib/schema';

const featuredTowns = ALL_TOWNS.slice(0, 10);

const title = 'Flooring & Cabinets in Murphy, NC — Carpet Mart | Since 1973';
const description =
  'Carpet Mart is a full-service flooring and cabinet store in Murphy, NC since 1973. We help you choose, measure and professionally install carpet, vinyl plank, hardwood, vinyl flooring, laminate and cabinets — free in-home quotes within 80 miles. Call (828) 837-7491.';

const faqs = [
  {
    question: 'Where is Carpet Mart located?',
    answer: `We're at ${ADDRESS_LINE}, right on US-64 West in Murphy. We're an easy drive for anyone in Cherokee, Clay and Graham counties, and only about an hour from Blairsville and Blue Ridge, Georgia.`,
  },
  {
    question: 'Do you handle the whole project, including installation?',
    answer:
      'Yes — that\'s what we do best. We help you choose the right floor, come out and measure, order the material, and our own experienced crews handle tear-out, subfloor prep and professional installation. You deal with one local company from start to finish.',
  },
  {
    question: 'How far do you travel to install?',
    answer:
      'We sell and install flooring for homes within about 80 miles of our Murphy showroom — across far Western North Carolina, North Georgia and Southeast Tennessee. If you\'re not sure whether you\'re in range, just give us a call.',
  },
  {
    question: 'How much does new flooring cost?',
    answer:
      'It depends on the material, the square footage and whether you need removal of old flooring and installation. The best way to get a real number is a free in-home measure and quote — we\'ll give you one clear, all-in price covering material, prep and installation.',
  },
  {
    question: 'How long has Carpet Mart been in business?',
    answer: `Since 1973 — that's over ${YEARS_IN_BUSINESS} years serving the same community in far Western North Carolina. We've helped multiple generations of local families with their floors.`,
  },
];

const valueProps = [
  {
    title: 'Full-service, start to finish',
    body: 'We handle the whole project — guidance, measuring, ordering and professional installation. You pick the floor you love; we take care of the rest.',
  },
  {
    title: 'Free in-home measure & quote',
    body: 'We come out, measure precisely and give you a clear, all-in quote — material, prep and install — so there are no surprises later.',
  },
  {
    title: `Family-run since ${SITE.foundedYear}`,
    body: `Over ${YEARS_IN_BUSINESS} years flooring the same mountain communities. We answer the phone, and we stand behind every floor we install.`,
  },
  {
    title: 'Installed within 80 miles',
    body: 'Our own experienced crews handle tear-out, subfloor prep and installation for homes across the region — done right the first time.',
  },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
  },
  localBusinessSchema,
  faqSchema(faqs),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="container-page grid items-center gap-10 py-12 lg:grid-cols-[1.05fr_1fr] lg:gap-14 lg:py-20">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wider text-stone-700">
          <span class="h-1.5 w-1.5 rounded-full bg-clay-600"></span>
          Murphy, NC &middot; Since {SITE.foundedYear}
        </span>
        <h1 class="mt-6 text-4xl font-extrabold leading-[1.05] tracking-tight text-stone-900 sm:text-5xl lg:text-6xl">
          Flooring you'll love,
          <span class="text-clay-700"> handled start to finish</span>.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-stone-600">
          Carpet, vinyl plank, hardwood, vinyl flooring, laminate — and now cabinets too. We take
          care of the whole project: helping you choose, measuring, and professionally installing it
          for you. One local company, from your first quote to the final board, for homes within
          80 miles of Murphy.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class="inline-flex items-center justify-center rounded-xl bg-clay-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm transition-all hover:bg-clay-700 active:scale-[0.98]">
            Get a free quote
          </a>
          <a href="/flooring" class="inline-flex items-center justify-center gap-2 rounded-xl border border-stone-300 bg-white px-6 py-3.5 text-base font-semibold text-stone-800 transition-all hover:border-stone-400 active:scale-[0.98]">
            Browse flooring
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
          </a>
        </div>

        <dl class="mt-10 grid max-w-lg grid-cols-3 gap-6 border-t border-stone-200 pt-6">
          <div>
            <dt class="text-3xl font-bold text-stone-900">{YEARS_IN_BUSINESS}+</dt>
            <dd class="mt-1 text-sm text-stone-500">Years in Murphy</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold text-stone-900">5</dt>
            <dd class="mt-1 text-sm text-stone-500">Flooring types</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold text-stone-900">80<span class="text-xl">mi</span></dt>
            <dd class="mt-1 text-sm text-stone-500">Service radius</dd>
          </div>
        </dl>
      </div>

      <div class="relative">
        <div class="overflow-hidden rounded-3xl border border-stone-200 shadow-xl shadow-stone-900/5">
          <img
            src="/images/storefront-exterior.avif"
            alt="The Carpet Mart flooring store on US Highway 64 West in Murphy, North Carolina"
            width="1200"
            height="900"
            fetchpriority="high"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>
        <div class="absolute -bottom-5 -left-5 hidden rounded-2xl border border-stone-200 bg-white px-5 py-4 shadow-lg sm:block">
          <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Find us on US-64 W</p>
          <p class="mt-1 font-mono text-sm font-medium text-stone-900">{SITE.address.street}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="container-page py-8">
    <div class="grid gap-px overflow-hidden rounded-2xl border border-stone-200 bg-stone-200 sm:grid-cols-2 lg:grid-cols-4">
      {valueProps.map((v) => (
        <div class="bg-stone-50 p-6">
          <h2 class="font-display text-lg font-bold text-stone-900">{v.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-stone-600">{v.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FLOORING CATEGORIES (bento) -->
  <section class="container-page py-16">
    <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Shop by floor</p>
        <h2 class="mt-2 max-w-xl text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">
          Every floor for every room in your home
        </h2>
      </div>
      <a href="/flooring" class="shrink-0 text-sm font-semibold text-clay-700 hover:text-clay-800">
        See all flooring &rarr;
      </a>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-6">
      {FLOORING_CATEGORIES.map((cat, i) => (
        <a
          href={`/flooring/${cat.slug}`}
          class:list={[
            'group relative flex flex-col justify-end overflow-hidden rounded-2xl border border-stone-200 bg-stone-900',
            i === 0 ? 'lg:col-span-3 lg:row-span-2 min-h-[18rem]' : 'lg:col-span-3 min-h-[14rem]',
          ]}
        >
          <img
            src={cat.image}
            alt={cat.imageAlt}
            width="800"
            height="600"
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover opacity-80 transition-all duration-500 group-hover:scale-105 group-hover:opacity-70"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-stone-950/90 via-stone-950/30 to-transparent"></div>
          <div class="relative p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-clay-300">{cat.short}</p>
            <h3 class="mt-1 font-display text-2xl font-bold text-white">{cat.name}</h3>
            <p class="mt-2 max-w-md text-sm leading-relaxed text-stone-200">{cat.blurb}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
              Explore {cat.name.toLowerCase()}
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CABINETS CALLOUT -->
  <section class="container-page pb-4">
    <a href="/cabinets" class="group block overflow-hidden rounded-3xl border border-stone-200 bg-stone-900">
      <div class="relative grid items-center gap-6 p-8 sm:p-12 lg:grid-cols-[1.5fr_1fr]">
        <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-clay-700/30 blur-3xl"></div>
        <div class="relative">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-clay-200">
            New at Carpet Mart
          </span>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">We do cabinets too</h2>
          <p class="mt-3 max-w-xl text-[1.0625rem] leading-relaxed text-stone-300">
            Kitchen cabinets, bathroom vanities and more — designed, measured and installed by the
            same team that does your floors. Coordinate the whole look with one local company.
          </p>
        </div>
        <div class="relative lg:justify-self-end">
          <span class="inline-flex items-center gap-2 rounded-xl bg-clay-600 px-6 py-3.5 text-base font-semibold text-white transition-all group-hover:bg-clay-500">
            Explore cabinets
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
          </span>
        </div>
      </div>
    </a>
  </section>

  <!-- STORY + SHOWROOM -->
  <section class="border-y border-stone-200 bg-white">
    <div class="container-page grid items-center gap-12 py-16 lg:grid-cols-2 lg:gap-16">
      <div class="order-2 grid grid-cols-2 gap-4 lg:order-1">
        <img src="/images/showroom-1.avif" alt="Carpet rolls and flooring displays inside the Carpet Mart showroom in Murphy" width="600" height="700" loading="lazy" class="aspect-[4/5] w-full rounded-2xl border border-stone-200 object-cover" />
        <div class="grid gap-4">
          <img src="/images/vinyl-rolls-1.avif" alt="Roll-up vinyl flooring on racks at Carpet Mart" width="600" height="340" loading="lazy" class="aspect-[16/10] w-full rounded-2xl border border-stone-200 object-cover" />
          <img src="/images/showroom-2.avif" alt="Hardwood and flooring samples at the Carpet Mart showroom" width="600" height="340" loading="lazy" class="aspect-[16/10] w-full rounded-2xl border border-stone-200 object-cover" />
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Since 1973</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">
          A real flooring store, run by real neighbors
        </h2>
        <div class="prose-body mt-5 space-y-4">
          <p>
            Carpet Mart opened its doors in Murphy back in 1973, and we've been helping families in
            Cherokee County and across the mountains pick the right floors ever since. When you walk
            in, you talk to people who actually know flooring — not a rotating staff reading from a
            screen.
          </p>
          <p>
            We keep a deep selection of carpet, <a href="/flooring/vinyl-plank" class="font-medium text-clay-700 underline decoration-clay-300 underline-offset-2 hover:decoration-clay-600">waterproof vinyl plank</a>,
            hardwood, vinyl flooring and laminate in stock — plus <a href="/cabinets" class="font-medium text-clay-700 underline decoration-clay-300 underline-offset-2 hover:decoration-clay-600">kitchen and bath cabinets</a> —
            so you can see and feel everything before you choose. Then we take it the rest of the way:
            measuring your rooms, ordering the material, and installing it with our own crews. It's the
            kind of full-service, end-to-end care a big-box store simply can't match.
          </p>
        </div>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/about" class="inline-flex items-center justify-center rounded-xl border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-800 transition-all hover:border-stone-400 active:scale-[0.98]">
            Our story
          </a>
          <a href="/areas-we-serve" class="inline-flex items-center justify-center rounded-xl border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-800 transition-all hover:border-stone-400 active:scale-[0.98]">
            Areas we serve
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MEET THE TEAM -->
  <TeamSection cta={true} />

  <!-- AREAS SERVED -->
  <section class="container-page py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Where we work</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">
        Flooring across the NC, GA &amp; TN mountains
      </h2>
      <p class="prose-body mt-4">
        From our showroom on US-64 in Murphy, we sell and install flooring for homes within about
        an 80-mile radius — {TOTAL_TOWNS} communities across {TOTAL_COUNTIES} counties in far
        Western North Carolina, North Georgia and Southeast Tennessee.
      </p>
    </div>
    <ul class="mt-8 flex flex-wrap gap-2.5">
      {featuredTowns.map(({ town, county }) => (
        <li>
          <a href={townPath(county, town)} class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-700 transition-colors hover:border-clay-300 hover:text-clay-700">
            {town.name}, {town.state}
          </a>
        </li>
      ))}
      <li>
        <a href="/areas-we-serve" class="inline-flex items-center gap-2 rounded-full border border-clay-200 bg-clay-50 px-4 py-2 text-sm font-semibold text-clay-700 transition-colors hover:bg-clay-100">
          View all areas &rarr;
        </a>
      </li>
    </ul>
  </section>

  <!-- TESTIMONIALS -->
  <section class="border-y border-stone-200 bg-white">
    <div class="container-page py-16">
      <h2 class="text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">What neighbors say</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {TESTIMONIALS.map((t) => (
          <figure class="flex flex-col rounded-2xl border border-stone-200 bg-stone-50 p-6">
            <div class="flex gap-0.5 text-clay-500">
              {Array.from({ length: t.rating }).map(() => (
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 0 0 .95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 0 0-.37 1.12l1.07 3.29c.3.92-.75 1.69-1.54 1.12l-2.8-2.03a1 1 0 0 0-1.17 0l-2.8 2.03c-.79.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 0 0-.37-1.12L2.96 8.72c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 0 0 .95-.69L9.05 2.93Z"/></svg>
              ))}
            </div>
            <blockquote class="mt-4 flex-1 text-[1.0625rem] leading-relaxed text-stone-700">&ldquo;{t.quote}&rdquo;</blockquote>
            <figcaption class="mt-4 text-sm">
              <span class="font-semibold text-stone-900">{t.name}</span>
              <span class="text-stone-500"> &middot; {t.location}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-page py-16">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Good to know</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl">
          Frequently asked questions
        </h2>
        <p class="prose-body mt-4">
          Still have a question? <a href="/contact" class="font-medium text-clay-700 underline decoration-clay-300 underline-offset-2 hover:decoration-clay-600">Get in touch</a> or call us at
          <a href={`tel:${SITE.phoneHref}`} class="font-mono font-medium text-clay-700">{SITE.phone}</a>.
        </p>
      </div>
      <FAQ client:visible items={faqs} />
    </div>
  </section>

  <div class="pb-24">
    <CtaBand />
  </div>
</BaseLayout>
