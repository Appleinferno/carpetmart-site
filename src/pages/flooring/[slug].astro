---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import FAQ from '../../components/FAQ.tsx';
import { FLOORING_DETAILS, FLOORING_SLUGS } from '../../lib/flooring-content';
import { FLOORING_CATEGORIES, SITE } from '../../lib/site';
import { localBusinessSchema, breadcrumbSchema, faqSchema } from '../../lib/schema';

export function getStaticPaths() {
  return FLOORING_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const detail = FLOORING_DETAILS[slug!];
if (!detail) return Astro.redirect('/flooring');

const related = detail.related
  .map((s) => FLOORING_CATEGORIES.find((c) => c.slug === s))
  .filter(Boolean);

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Flooring', path: '/flooring/' },
  { name: detail.name, path: `/flooring/${detail.slug}/` },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: `${detail.name} flooring sales & installation`,
    serviceType: `${detail.name} flooring`,
    description: detail.metaDescription,
    provider: { '@id': `${SITE.url}/#business` },
    areaServed: { '@type': 'AdministrativeArea', name: 'Cherokee County, NC and surrounding NC, GA & TN mountains' },
    url: `${SITE.url}/flooring/${detail.slug}`,
  },
  localBusinessSchema,
  breadcrumbSchema(crumbs),
  faqSchema(detail.faqs),
];
---

<BaseLayout title={detail.metaTitle} description={detail.metaDescription} ogImage={detail.heroImage} structuredData={structuredData}>
  <Breadcrumbs items={crumbs} />

  <!-- HERO -->
  <section class="container-page grid items-center gap-10 py-10 lg:grid-cols-[1.05fr_1fr] lg:gap-14 lg:py-14">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">{detail.heroEyebrow}</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.07] tracking-tight text-stone-900 sm:text-5xl">
        {detail.heroHeading}
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-stone-600">{detail.heroLead}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a href="/contact/" class="inline-flex items-center justify-center rounded-xl bg-clay-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm transition-all hover:bg-clay-700 active:scale-[0.98]">
          Get a free quote
        </a>
        <a href={`tel:${SITE.phoneHref}`} class="inline-flex items-center justify-center gap-2 rounded-xl border border-stone-300 bg-white px-6 py-3.5 text-base font-semibold text-stone-800 transition-all hover:border-stone-400 active:scale-[0.98]">
          <svg class="h-5 w-5 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
          <span class="font-mono">{SITE.phone}</span>
        </a>
      </div>
      <p class="mt-4 text-sm text-stone-500">{detail.priceNote}</p>
    </div>
    <div class="overflow-hidden rounded-3xl border border-stone-200 shadow-xl shadow-stone-900/5">
      <img src={detail.heroImage} alt={detail.heroImageAlt} width="1000" height="800" fetchpriority="high" class="aspect-[5/4] w-full object-cover" />
    </div>
  </section>

  <!-- INTRO + BEST FOR -->
  <section class="container-page grid gap-12 py-10 lg:grid-cols-[1.4fr_1fr] lg:gap-16">
    <div class="prose-body space-y-5">
      <h2 class="font-display text-2xl font-bold text-stone-900">Why {detail.name.toLowerCase()} might be right for you</h2>
      {detail.intro.map((p) => <p>{p}</p>)}
    </div>
    <aside class="rounded-2xl border border-stone-200 bg-white p-6">
      <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Best for</h3>
      <ul class="mt-4 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
        {detail.bestFor.map((b) => (
          <li class="flex items-center gap-2 text-sm font-medium text-stone-700">
            <svg class="h-4 w-4 shrink-0 text-clay-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
            {b}
          </li>
        ))}
      </ul>
    </aside>
  </section>

  <!-- OPTIONS -->
  <section class="border-y border-stone-200 bg-white">
    <div class="container-page py-14">
      <h2 class="max-w-2xl text-3xl font-bold tracking-tight text-stone-900">{detail.name} styles &amp; options we carry</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {detail.options.map((o) => (
          <div class="rounded-2xl border border-stone-200 bg-stone-50 p-6">
            <h3 class="font-display text-lg font-bold text-stone-900">{o.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{o.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONSIDERATIONS -->
  <section class="container-page py-14">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-clay-700">Buying tips</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-stone-900">What to think about before you buy</h2>
        <p class="prose-body mt-4">Not sure where to start? That's what we're here for. Walk in and we'll talk it through with you — no pressure.</p>
      </div>
      <div class="divide-y divide-stone-200 border-y border-stone-200">
        {detail.considerations.map((c) => (
          <div class="py-5">
            <h3 class="font-display text-lg font-semibold text-stone-900">{c.title}</h3>
            <p class="mt-1.5 max-w-[65ch] text-[1.0625rem] leading-relaxed text-stone-600">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL ANGLE -->
  <section class="container-page py-6">
    <div class="rounded-3xl border border-clay-200 bg-clay-50 p-8 sm:p-10">
      <h2 class="font-display text-2xl font-bold text-stone-900">Local advice for mountain homes</h2>
      <p class="prose-body mt-3 max-w-3xl">{detail.localAngle}</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container-page py-14">
    <h2 class="text-3xl font-bold tracking-tight text-stone-900">{detail.name} questions, answered</h2>
    <div class="mt-8 max-w-3xl">
      <FAQ client:visible items={detail.faqs} />
    </div>
  </section>

  <!-- RELATED -->
  {related.length > 0 && (
    <section class="container-page py-6">
      <h2 class="text-2xl font-bold tracking-tight text-stone-900">Compare other flooring</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {related.map((c) => (
          <a href={`/flooring/${c!.slug}/`} class="group flex items-center justify-between gap-3 rounded-2xl border border-stone-200 bg-white p-5 transition-all hover:border-clay-300 hover:shadow-sm">
            <div>
              <h3 class="font-display text-lg font-bold text-stone-900">{c!.name}</h3>
              <p class="mt-0.5 text-sm text-stone-500">{c!.short}</p>
            </div>
            <svg class="h-5 w-5 shrink-0 text-clay-600 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0-6-6m6 6-6 6"/></svg>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="pt-10 pb-24">
    <CtaBand heading={`Let's plan your new ${detail.name.toLowerCase()}`} />
  </div>
</BaseLayout>
